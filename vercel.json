{
  "version": 2,
  "crons": [
    {
      "path": "/api/process-scheduled",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/send-weekly-report",
      "schedule": "0 18 * * 0"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/reader\\.html",
      "dest": "/reader.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
