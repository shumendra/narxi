# Supabase configuration
SUPABASE_URL="your-supabase-url"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
VITE_SUPABASE_URL="your-supabase-url"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_ADMIN_TELEGRAM_ID="your-telegram-id"

# Scan API URL — set to your Vercel API URL for receipt scanning
# e.g. https://your-vercel-app.vercel.app/api/scan
VITE_SCAN_API_URL=""

# Telegram configuration
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_MINI_APP_URL="https://your-mini-app-url"
ADMIN_TELEGRAM_ID="your-telegram-id"
# Optional: comma-separated admin IDs
# ADMIN_TELEGRAM_IDS="123456789,987654321"

# Notification security
NOTIFICATION_SECRET="generate_a_random_string_here"

# AI normalization (server-side)
GEMINI_API_KEY="your-gemini-api-key"
# Optional model override
# GEMINI_MODEL="gemini-2.0-flash"
